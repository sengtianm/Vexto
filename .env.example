# ===========================
# Claves API de Groq (Obligatorias)
# ===========================
# Clave principal para Whisper y Llama 3.3
GROQ_API_KEY=tu_clave_aqui

# Clave secundaria de respaldo (opcional pero recomendada)
GROQ_API_KEY_2=tu_segunda_clave_aqui

# ===========================
# NOTA: Las demás configuraciones (atajo, idioma, micrófono, etc.)
# se manejan automáticamente en config.user.json
# No es necesario agregarlas aquí.
# ===========================
